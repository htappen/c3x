#!/usr/bin/env python3
from __future__ import annotations

import re
import sys
from pathlib import Path


def main() -> int:
    args = sys.argv[1:]
    prompt = args[-1] if args else ""
    result_match = re.search(r"Write the final JSON result to `([^`]+)`", prompt)
    if result_match:
        result = Path(result_match.group(1))
        result.parent.mkdir(parents=True, exist_ok=True)
        task_match = re.search(r"Task: ([^\n]+)", prompt)
        task_id = task_match.group(1).strip() if task_match else "bd-1"
        result.write_text(
            '{"task_id":"%s","status":"completed","summary":"fake OpenCode done"}\n' % task_id,
            encoding="utf-8",
        )
    changed = Path.cwd() / "FAKE_OPENCODE.md"
    changed.write_text("# Greeting\n\nHello from fake OpenCode.\n", encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
