#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path


def main() -> int:
    # 1. Determine worktree path
    worktree = Path(".")
    if "--add-dir" in sys.argv:
        try:
            idx = sys.argv.index("--add-dir")
            worktree = Path(sys.argv[idx + 1])
        except (ValueError, IndexError):
            pass

    # 2. Determine prompt content
    prompt_content = ""
    if "--print" in sys.argv:
        try:
            idx = sys.argv.index("--print")
            prompt_content = sys.argv[idx + 1]
        except (ValueError, IndexError):
            pass
    elif sys.argv:
        prompt_content = sys.argv[-1]

    # 3. Parse task ID from prompt content
    task_id = "unknown"
    for line in prompt_content.splitlines():
        if line.startswith("Task: "):
            task_id = line.removeprefix("Task: ").strip()
            break

    # 4. Make changes in worktree
    changed = worktree / "GREETING.md"
    changed.write_text("# Greeting\n\nHello from fake Antigravity.\n", encoding="utf-8")
    
    subprocess.run(["git", "config", "user.email", "c3x@example.invalid"], cwd=worktree, check=True)
    subprocess.run(["git", "config", "user.name", "c3x fake worker"], cwd=worktree, check=True)
    subprocess.run(["git", "add", "GREETING.md"], cwd=worktree, check=True)
    subprocess.run(["git", "commit", "-m", f"Complete {task_id}"], cwd=worktree, check=True)

    # 5. Write the result file
    result = worktree / ".c3x" / "result.json"
    result.parent.mkdir(parents=True, exist_ok=True)
    result.write_text(
        json.dumps(
            {
                "task_id": task_id,
                "status": "completed",
                "summary": "Created GREETING.md",
                "task_kind": "feature",
                "attempt": 1,
                "changed_files": ["GREETING.md"],
                "verification": [],
                "blockers": [],
                "blocker_category": None,
                "proposed_tasks": [],
                "scope_expansion": [],
                "confidence": "high",
                "unfinished": [],
            },
            indent=2,
        )
        + "\n",
        encoding="utf-8",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
