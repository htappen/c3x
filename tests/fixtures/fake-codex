#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path


def main() -> int:
    prompt = Path(sys.argv[-2])
    result = Path(sys.argv[-1])
    text = prompt.read_text(encoding="utf-8")
    task_id = "unknown"
    for line in text.splitlines():
        if line.startswith("Task: "):
            task_id = line.removeprefix("Task: ").strip()
            break

    changed = Path("GREETING.md")
    changed.write_text("# Greeting\n\nHello from fake Codex.\n", encoding="utf-8")
    subprocess.run(["git", "config", "user.email", "c3x@example.invalid"], check=True)
    subprocess.run(["git", "config", "user.name", "c3x fake worker"], check=True)
    subprocess.run(["git", "add", "GREETING.md"], check=True)
    subprocess.run(["git", "commit", "-m", f"Complete {task_id}"], check=True)

    result.parent.mkdir(parents=True, exist_ok=True)
    result.write_text(
        json.dumps(
            {
                "task_id": task_id,
                "status": "completed",
                "summary": "Created GREETING.md",
                "task_kind": "feature",
                "attempt": 1,
                "changed_files": ["GREETING.md"],
                "verification": [],
                "blockers": [],
                "blocker_category": None,
                "proposed_tasks": [],
                "scope_expansion": [],
                "confidence": "high",
                "unfinished": [],
            },
            indent=2,
        )
        + "\n",
        encoding="utf-8",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
